          "segment_id": "pre_move",
          "kind": "move",
          "mobility_source": "surface",
          "optional": true
        },
        {
          "segment_id": "attack",
          "kind": "attack",
          "max_uses": 1,
          "optional": true
        }
      ],
      "is_atomic": true,
      "move_and_attack_mutually_exclusive": false,
      "examples_of_legal_sequences": [
        "move",
        "attack",
        "move-attack"
      ]
    },

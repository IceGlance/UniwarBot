          "examples_of_legal_sequences": [
            "buried-move",
            "unbury",
            "unbury-attack"
          ],
          "examples_of_illegal_sequences": [
            "buried-move-attack",
            "unbury-wait-attack",
            "unbury-other_unit_acts-attack"
          ]
        }

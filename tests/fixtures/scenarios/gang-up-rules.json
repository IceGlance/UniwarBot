    {
      "name": "marauder second hit from same hex gets +2 and keeps carried seed",
      "actions": [
        {
          "type": "attack_unit",
          "attacker_id": "u_attacker",
          "defender_id": "u_defender"
        },
        {
          "type": "assert_gang_up_bonus",
          "attacker_id": "u_attacker",
          "defender_id": "u_defender",
          "expected_bonus": 2,
          "name": "same hex +2"
        },
        {
          "type": "attack_unit",
          "attacker_id": "u_attacker",
          "defender_id": "u_defender"
        }
      ],
      "expected_changes": {
        "current_rseed": 5176335776358260987,
        "units.u_defender.hp": 12,
        "fight_context.chain_index": 2,
        "units.u_attacker": "__missing__"
      },

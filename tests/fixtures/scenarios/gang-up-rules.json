{
  "name": "Gang Up Rules",
  "cases": [
    {
      "name": "marauder second hit from same hex gets +2 and keeps carried seed",
      "input_state_data": {
        "ruleset_version": "test-v1",
        "current_rseed": 12345,
        "active_player_id": "p1",
        "players": [
          {
            "player_id": "p1",
            "faction": "sapiens"
          },
          {
            "player_id": "p2",
            "faction": "sapiens"
          }
        ],
        "tiles": [
          {
            "coord": "1:0",
            "terrain_id": "plain"
          },
          {
            "coord": "0:0",
            "terrain_id": "plain"
          }
        ],
        "units": [
          {
            "instance_id": "u_attacker",
            "unit_id": "marauder",
            "owner_id": "p1",
            "coord": "1:0",
            "hp": 10,
            "action": {
              "configured_action_count": 2,
              "actions_remaining": 2,
              "attacks_remaining": 2
            }
          },
          {
            "instance_id": "u_defender",
            "unit_id": "tank",
            "owner_id": "p2",
            "coord": "0:0",
            "hp": 12
          }
        ],
        "metadata": {
          "income_per_base": 100,
          "income_per_city": 50
        },
        "map_id": "gang-up",
        "map_name": "Gang Up Rules"
      },
      "actions": [
        {
          "type": "attack_unit",
          "attacker_id": "u_attacker",
          "defender_id": "u_defender"
        },
        {
          "type": "assert_gang_up_bonus",
          "attacker_id": "u_attacker",
          "defender_id": "u_defender",
          "expected_bonus": 2,
          "name": "same hex +2"
        },
        {
          "type": "attack_unit",
          "attacker_id": "u_attacker",
          "defender_id": "u_defender"
        }
      ],
      "expected_changes": {
        "current_rseed": 5176335776358260987,
        "units.u_defender.hp": 12,
        "fight_context.chain_index": 2,
        "units.u_attacker": "__missing__"
      }
    },

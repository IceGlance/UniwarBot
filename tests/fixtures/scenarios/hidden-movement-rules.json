{
  "name": "Hidden Movement Rules",
  "cases": [
    {
      "name": "buried underling ignores surface zoc and can move under a surface unit",
      "input_state_data": {
        "active_player_id": "p1",
        "players": [
          {
            "player_id": "p1",
            "faction": "khraleans"
          },
          {
            "player_id": "p2",
            "faction": "sapiens"
          }
        ],
        "tiles": [
          {
            "coord": "0:0",
            "terrain_id": "plain"
          },
          {
            "coord": "1:0",
            "terrain_id": "plain"
          },
          {
            "coord": "2:0",
            "terrain_id": "plain"
          }
        ],
        "units": [
          {
            "instance_id": "u_underling",
            "unit_id": "underling",
            "owner_id": "p1",
            "coord": "0:0",
            "status": {
              "hidden_mode": "buried"
            },
            "action": {
              "is_available": true,
              "configured_action_count": 1,
              "actions_remaining": 1,
              "move_points_remaining": 6,
              "attacks_remaining": 1
            }
          },
          {
            "instance_id": "u_enemy",
            "unit_id": "marine",
            "owner_id": "p2",
            "coord": "1:0",
            "action": {
              "is_available": true,
              "configured_action_count": 1,
              "actions_remaining": 1,
              "attacks_remaining": 1
            }
          }
        ]
      },
      "actions": [
        {
          "type": "assert_possible_moves",
          "unit_id": "u_underling",
          "expected": {
            "unit_id": "u_underling",
            "move_points": 6,
            "move_destinations": [
              "1:0",
              "2:0"
            ],
            "legal_move_destinations": [
              "1:0",
              "2:0"
            ],
            "move_requires_attack": false,
            "move_attack_targets": {},
            "can_bury": false,
            "can_resurface": true,
            "can_resurface_attack": true,
            "resurface_attack_targets": [
              "u_enemy"
            ]
          }
        }
      ]
    },
    {
      "name": "buried underling move keeps surface unit and occupies hidden slot on destination",

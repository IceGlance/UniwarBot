            "owner_id": "p2",
            "coord": "1:0",
            "action": {
              "is_available": true,
              "configured_action_count": 1,
              "actions_remaining": 1,
              "attacks_remaining": 1
            }
          }
        ]
      },
      "actions": [
        {
          "type": "move_unit",
          "unit_id": "u_underling",
          "destination": "1:0"
        }
      ],
      "expected_changes": {
        "tile.0:0.hidden_unit_id": {
          "before": "u_underling",
          "after": null
        },
        "tile.1:0.hidden_unit_id": {
          "before": null,
          "after": "u_underling"
        },
        "units.u_underling.action.actions_remaining": {
          "before": 1,
          "after": 0
        },
        "units.u_underling.action.has_moved_this_turn": {
          "before": false,
          "after": true
        },
        "units.u_underling.position.q": {
          "before": 0,
          "after": 1
        }
      }
    },

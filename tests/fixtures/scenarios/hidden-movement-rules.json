          }
        ],
        "units": [
          {
            "instance_id": "u_underling",
            "unit_id": "underling",
            "owner_id": "p1",
            "coord": "0:0",
            "status": {
              "hidden_mode": "buried"
            },
            "action": {
              "is_available": true,
              "configured_action_count": 1,
              "actions_remaining": 1,
              "move_points_remaining": 3,

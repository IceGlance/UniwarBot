{
  "name": "ending_p2_turn_starts_p1_turn_with_teleported_unit_movement_blocked",
  "suite_name": "Teleport Lock Rules",
  "case_name": "ending p2 turn starts p1 turn with teleported unit movement blocked",
  "input_state": "states/teleport-opponent-turn.json",
  "actions": [
    {
      "type": "end_turn"
    }
  ],
  "expected_changes": {
    "active_player_id": {
      "before": "p2",
      "after": "p1"
    },
    "players.p1.has_ended_turn": {
      "before": true,
      "after": false
    },
    "players.p2.has_ended_turn": {
      "before": false,
      "after": true
    },
    "round_number": {
      "before": 2,
      "after": 3
    },
    "turn_number": {
      "before": 2,
      "after": 3
    },
    "units.u_mecha.action.actions_remaining": {
      "before": 0,
      "after": 1
    },
    "units.u_mecha.action.attacks_remaining": {
      "before": 0,
      "after": 1
    },
    "units.u_mecha.action.is_available": {
      "before": false,
      "after": true
    },
    "units.u_mecha.status.control_zones_suppressed": {
      "before": true,
      "after": false
    },
    "units.u_mecha.status.movement_blocked": {
      "before": false,
      "after": true
    },
    "units.u_mecha.status.retaliation_blocked": {
      "before": true,
      "after": false
    },
    "units.u_mecha.status.teleport_lock_phase": {
      "before": "opponent_turn",
      "after": "owner_turn"
    }
  }
}
